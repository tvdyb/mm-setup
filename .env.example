# Copy to .env (or export in your shell) and fill in.
# .env is gitignored.

# Kalshi API access key UUID (Settings → API Keys)
KALSHI_KEY_ID=00000000-0000-0000-0000-000000000000

# Path to the matching RSA private key file (PEM)
KALSHI_KEY_PATH=./private_key.pem

# Optional: persisted state files used by kalshi_rewards_app.py
KALSHI_FOLLOWED_PATH=./kalshi_followed_events.json
KALSHI_BLOCKED_PATH=./kalshi_blocked_markets.json
KALSHI_MONITOR_LOG=./kalshi_reward_monitor.log
